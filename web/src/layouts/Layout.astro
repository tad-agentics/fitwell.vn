---
/**
 * Base layout — fonts, global CSS, viewport. InAppBanner on every page (P3).
 */
import '../styles/globals.css';
import InAppBanner from '../components/shared/InAppBanner';
interface Props {
  title?: string;
}
const { title = 'FitWell' } = Astro.props;
---
<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&family=Figtree:wght@400;600;700;800;900&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <InAppBanner client:load />
  </body>
</html>
