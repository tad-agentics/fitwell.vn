# FitWell — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
#
# Deployment split:
#   Server-side vars  → DigitalOcean App Platform (fitwell-api)
#   Frontend vars     → Vercel (fitwell-web) — PUBLIC_ prefix only
#
# Security rules (non-negotiable):
#   SUPABASE_SERVICE_ROLE_KEY must NOT be in Vercel env vars
#   PAYOS_* must NOT be in Vercel env vars
#   JWT_SECRET must NOT be in Vercel env vars
#   Only PUBLIC_* vars are safe to expose to the browser

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE — Supabase (server-side only)
# ─────────────────────────────────────────────────────────────────────────────
# DATABASE_URL = Postgres connection URI (required for api).
# Supabase: Project Settings → Database → Connection string (Session mode).
# Format: postgresql://postgres.[ref]:[DB-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
# RLS must be DISABLED on all tables — all access via backend only.

DATABASE_URL=postgresql://postgres.your-ref:your-db-password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# SUPABASE_ANON_KEY is intentionally absent — anon key is not used

# ─────────────────────────────────────────────────────────────────────────────
# AUTH — JWT (server-side only)
# ─────────────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Minimum 32 chars random. Changing this invalidates all existing tokens.

JWT_SECRET=replace-with-32-char-minimum-random-string

# ─────────────────────────────────────────────────────────────────────────────
# AUTH — Google OAuth (server-side only)
# ─────────────────────────────────────────────────────────────────────────────
# Where to get: Google Cloud Console → APIs & Services → Credentials
# Redirect URI to register: https://api.fitwell.vn/api/v1/auth/google/callback

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─────────────────────────────────────────────────────────────────────────────
# AI — OpenRouter (server-side only)
# ─────────────────────────────────────────────────────────────────────────────
# Where to get: openrouter.ai → Keys. Routes to Claude (e.g. anthropic/claude-3-haiku).
# Used by: checkin AI response (standard branch). Set to enable live AI; omit for template fallback.
# Never commit the real key — set in .env or deployment env only.

OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Legacy (optional): direct Anthropic — used only if OPENROUTER_API_KEY not set
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─────────────────────────────────────────────────────────────────────────────
# WEB PUSH — VAPID (server-side only)
# ─────────────────────────────────────────────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY is also served via GET /api/v1/config/push-key (no auth)
# Do not regenerate in production — invalidates all existing subscriptions

VAPID_PUBLIC_KEY=your-vapid-public-key-base64url
VAPID_PRIVATE_KEY=your-vapid-private-key-base64url
VAPID_SUBJECT=mailto:admin@fitwell.vn

# ─────────────────────────────────────────────────────────────────────────────
# PAYMENT — PayOS (server-side only)
# ─────────────────────────────────────────────────────────────────────────────
# Where to get: PayOS Dashboard → Kênh thanh toán → API Keys
# Register webhook URL in PayOS dashboard:
#   https://api.fitwell.vn/api/v1/billing/payos-webhook

PAYOS_CLIENT_ID=your-payos-client-id
PAYOS_API_KEY=your-payos-api-key
PAYOS_CHECKSUM_KEY=your-payos-checksum-key

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL — Resend (server-side only)
# ─────────────────────────────────────────────────────────────────────────────
# Where to get: resend.com → API Keys
# Used for: welcome email, retention sequence (D+2, D+4, D+6, D+7), password reset
# Free tier: 3,000 emails/month — sufficient for MVP

RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=noreply@fitwell.vn

# ─────────────────────────────────────────────────────────────────────────────
# VIDEO — Cloudflare Stream (server-side only)
# ─────────────────────────────────────────────────────────────────────────────
# Where to get: Cloudflare dashboard → Stream → API tokens
# Used for: generating signed video URLs in exercise responses

CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_STREAM_API_TOKEN=your-cloudflare-stream-token

# ─────────────────────────────────────────────────────────────────────────────
# MONITORING — Sentry (server-side only)
# ─────────────────────────────────────────────────────────────────────────────
# Where to get: sentry.io → Project Settings → Client Keys (DSN)
# Add in Phase 6 (Launch Prep) — not required for local dev

SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ─────────────────────────────────────────────────────────────────────────────
# ANALYTICS — PostHog (server-side only)
# ─────────────────────────────────────────────────────────────────────────────
# Where to get: posthog.com → Project → Settings → Project API Key
# Used for server-side funnel events

POSTHOG_API_KEY=phc_your-posthog-project-api-key
POSTHOG_HOST=https://app.posthog.com

# ─────────────────────────────────────────────────────────────────────────────
# CRON (server-side only)
# ─────────────────────────────────────────────────────────────────────────────
# Secret for cron endpoints: X-Cron-Secret header. Set in scheduler (e.g. 03:00 pattern-detection, 06:50 morning-critical).
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"

CRON_SECRET=your-cron-secret-here

# ─────────────────────────────────────────────────────────────────────────────
# SERVER CONFIG (server-side only)
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:4321
# Production: CORS_ORIGIN=https://fitwell.vn

# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND — Vercel env vars (PUBLIC_ prefix — safe to expose)
# ─────────────────────────────────────────────────────────────────────────────
# These go in Vercel env vars dashboard, NOT in DigitalOcean

PUBLIC_API_URL=http://localhost:3001
# Production: PUBLIC_API_URL=https://api.fitwell.vn

PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Used only for Google OAuth redirect URI construction — no DB access

PUBLIC_POSTHOG_KEY=phc_your-posthog-project-api-key
# Client-side analytics — safe to expose

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — Not implemented in Web MVP
# ─────────────────────────────────────────────────────────────────────────────

# SMS 2FA — ESMS.vn (not implemented, reserve for future)
# ESMS_API_KEY=your-esms-api-key
# ESMS_SECRET_KEY=your-esms-secret-key
